<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:flexWrap="wrap">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/total_log_file"
            style="@style/button_style"
            android:text="全部异常文件" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/main_thread_lag_trigger"
            style="@style/button_style"
            android:text="触发主线程慢分发" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/java_crash_trigger"
            style="@style/button_style"
            android:text="触发 java crash" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/native_crash_trigger"
            style="@style/button_style"
            android:text="触发 native crash" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/anr_trigger"
            style="@style/button_style"
            android:text="触发 ANR (需点击屏幕)" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/memory_leak_trigger"
            style="@style/button_style"
            android:text="触发内存泄漏" />

    </com.google.android.flexbox.FlexboxLayout>

    <com.proxy.service.testview.DemoTestView
        android:id="@+id/content"
        style="@style/content_style" />

</androidx.appcompat.widget.LinearLayoutCompat>
