<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 共享应用的内部文件目录 -->
    <files-path
        name="internal_files"
        path="." />

    <!-- 共享应用的缓存目录 -->
    <cache-path
        name="cache_files"
        path="." />

    <!-- 共享外部存储的私有文件目录 -->
    <external-path
        name="external_files"
        path="." />

    <!-- 共享外部存储的特定子目录 -->
    <external-path
        name="external_images"
        path="Pictures/" />

</paths>