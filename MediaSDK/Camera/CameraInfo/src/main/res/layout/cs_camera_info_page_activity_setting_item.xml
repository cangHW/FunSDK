<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/cs_media_camera_setting_item_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:tint="#E6FFFFFF"
        tools:srcCompat="@android:drawable/ic_menu_crop" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/cs_media_camera_setting_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="拍照"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/cs_media_camera_setting_item_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/cs_camera_info_setting_smile_desc"
            android:textColor="#99FFFFFF"
            android:textSize="15sp"
            android:visibility="gone" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/cs_media_camera_setting_item_text_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/cs_media_camera_setting_item_text_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cs_camera_info_setting_value_full"
                android:textColor="#99FFFFFF"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="4dp"
                app:srcCompat="@drawable/cs_camera_info_chevron_right" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/cs_media_camera_setting_item_text_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:visibility="gone" />

    </FrameLayout>


</androidx.appcompat.widget.LinearLayoutCompat>